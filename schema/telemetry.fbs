namespace controls_middleware;

table Telemetry {
    device_id: uint16;
    status: uint8;
    timestamp: uint64;
    value: float32;
}

table Command {
    device_id: uint16;
    timestamp: uint64;
    cmd: string;
}

table Heartbeat {
    device_id: uint16;
    timestamp: uint64;
}

union Payload {
    Telemetry,
    Command,
    Heartbeat
}

table Message {
    payload: Payload;
} 

root_type Message;